{
  "expo": {
    "name": "ExpressMartAdmin",
    "slug": "ExpressMartAdmin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/express.png",
    "userInterfaceStyle": "light",
    "scheme": "expressmartadmin",
    "splash": {
      "image": "./assets/express.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stephenj3.ExpressMartAdmin",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.stephenj3.ExpressMartAdmin",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/express.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/express.png",
          "color": "#ffffff",
          "androidMode": "default",
          "androidCollapsedTitle": "ExpressMart Admin"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "61952e80-1f36-4b9a-9b0a-80883844379e"
      },
      "firebaseApiKey": "AIzaSyBqrV1yGWsLj17JXFwfIWRP-sqX6hp8vLk",
      "firebaseAuthDomain": "expressmart-7d550.firebaseapp.com",
      "firebaseProjectId": "expressmart-7d550",
      "firebaseStorageBucket": "expressmart-7d550.firebasestorage.app",
      "firebaseMessagingSenderId": "499123636329",
      "firebaseAppId": "1:499123636329:web:9a96c3d4b6ed11c3f57af8",
      "firebaseVapidKey": "YOUR_VAPID_KEY"
    }
  }
}
